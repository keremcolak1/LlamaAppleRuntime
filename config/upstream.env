# Pinned upstream source for the custom llama.cpp Apple runtime.
# Keep this exact. Do not track upstream master automatically.

LLAMA_CPP_REPOSITORY=https://github.com/ggml-org/llama.cpp.git
LLAMA_CPP_REVISION=b8827
LLAMA_APPLE_FETCH_MODE=archive

# Artifact naming used by scripts and Package.swift.
LLAMA_APPLE_PRODUCT_NAME=LlamaApple
LLAMA_APPLE_FRAMEWORK_NAME=LlamaApple
LLAMA_APPLE_ZIP_NAME=LlamaApple.xcframework.zip

# This version belongs to the binary packaging repo, not to upstream llama.cpp.
LLAMA_APPLE_RELEASE_VERSION=0.1.0-dev

# Comma-separated build matrix. Device + simulator are
# the default release slices. Add macos when local desktop consumers are needed.
LLAMA_APPLE_PLATFORMS=ios-device,ios-simulator

IOS_MIN_OS_VERSION=16.4
MACOS_MIN_OS_VERSION=13.3
